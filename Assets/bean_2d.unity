--- !u!114 &2079836683
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 2079836681}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\r\n1.Ofici\u0101lai Mistera B\u012Bna m\u0101jaslapai port\u0101l\u0101
    FACEBOOK.COM ir vair\u0101k sekot\u0101ju nek\u0101 pasaulslavenajai m\u016Bzi\u0137ei
    Britnijai Sp\u012Brsai vai futbola zvaigznei Deividam Bekhemam.\r\n\r\n2.Mistera
    B\u012Bna t\u0113la pirmais v\u0101rds bija Misters Vaits jeb Misters Baltais,
    ta\u010Du komi\u0137is Rovans to p\u0101rd\u0113v\u0113ja par Misteru Ziedk\u0101postu,
    bet v\u0113l\u0101k par Misteru Pupu jeb Misteru B\u012Bnu!\r\n\r\n3.Ziemassv\u0113tku
    vec\u012B\u0161a mazais pal\u012Bgs no Simpsoniem ir greihaunds, kas ir viena
    no eleganto su\u0146u \u0161\u0137irn\u0113m. Bet Simpsonos \u0161o sun\u012Bti
    izsmej d\u0113\u013C vi\u0146a janc\u012Bg\u0101 izskata.\r\n\r\n4.NASA m\u0101jaslap\u0101
    var pieteikties, lai sa\u0146emtu zi\u0146u e-past\u0101 ikreiz, kad p\u0101r
    Tavu galvu p\u0101rlido Starptautisk\u0101 kosmisa stacija. ( ne jau burtisk\u0101
    noz\u012Bm\u0113 emotion )\r\n\r\n5.Voltam Disnejam bija fobija no pel\u0113m.\r\n\r\n6.No
    40'000 zirnek\u013Cveid\u012Bgo sugu tikai 30 sugu zirnek\u013Cu kodiens var
    b\u016Bt b\u012Bstams cilv\u0113ka dz\u012Bv\u012Bbai.\r\n\r\n7.Visvair\u0101k
    Valent\u012Bndienas kart\u012B\u0161u sa\u0146em skolot\u0101ji.\r\n\r\n8.300
    min\u016B\u0161u - tik dienas laik\u0101, sp\u0113l\u0113jot \"Angry birds\",
    pavada visas zemeslodes iedz\u012Bvot\u0101ji (kop\u0101 nevis viens)\r\n\r\n9.(Bizbiz)
    m\u0101r\u012Bte elpo pa atver\u0113m \u0137erme\u0146a s\u0101nos.\r\n\r\n10.Pirm\u0101
    FACEBOOK.COM aug\u0161upiel\u0101d\u0113t\u0101 bilde bija z\u012Bm\u0113ts ka\u0137is."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
